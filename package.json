{
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.48.2",
    "@typescript-eslint/parser": "^5.48.2",
    "cpx": "^1.5.0",
    "electron": "^22.0.2",
    "eslint": "^8.32.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-config-standard-with-typescript": "^27.0.1",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-n": "^15.6.1",
    "eslint-plugin-promise": "^6.1.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.8.3",
    "sass": "^1.57.1",
    "typescript": "^4.9.4"
  },
  "name": "storm-n-tracs-editor",
  "description": "Area Editor of N-TRACS for Stormworks",
  "version": "0.1.0",
  "main": "dist/main.js",
  "scripts": {
    "prestart": "npm-run-all build:rm build",
    "start": "electron .",
    "build": "npm-run-all build:nodelatest build:main",
    "build:nodelatest": "nvm use",
    "build:main": "npm-run-all --parallel build:scss build:ts-main build:ts-browser build:pixi build:copy",
    "build:scss": "sass src/ui:dist",
    "build:rm": "rimraf dist/*",
    "build:pixi": "cpx node_modules/pixi.js/dist/pixi.min.js{,.map} dist",
    "build:ts-main": "tsc -p tsconfig.cjs.json",
    "build:ts-browser": "tsc -p tsconfig.esm.json",
    "build:copy": "cpx src/ui/**/*.{html,css} dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nona-takahara/storm-n-tracs-editor.git"
  },
  "author": "Nona Takahara",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nona-takahara/storm-n-tracs-editor/issues"
  },
  "homepage": "https://github.com/nona-takahara/storm-n-tracs-editor#readme",
  "dependencies": {
    "fast-xml-parser": "^4.0.13",
    "pixi.js": "^7.1.0"
  }
}
